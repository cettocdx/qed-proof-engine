# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# bulky regenerable data — keep ledger/positions, skip caches & logs
lib/data/market-cache/
lib/data/*.log

# customer PII & secrets-bearing runtime data — NEVER commit
lib/data/subscribers.jsonl
lib/data/payments.jsonl
lib/data/pending-orders.jsonl
lib/data/reminders-sent.jsonl
lib/data/equity-snapshots.jsonl
lib/data/equity-peaks.json
lib/data/scheduler-lock.json
lib/data/scheduler-errors.jsonl
lib/data/waitlist.jsonl
lib/data/backups/

